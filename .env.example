# Use the real IBM Granite/watsonx provider for final partner proof.
# Set MODEL_PROVIDER=mock only for rehearsals, CI, or quota-failure fallback.
MODEL_PROVIDER=watsonx
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=replace_me
WATSONX_APIKEY=replace_me
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# Never commit real API keys. Copy this file to .env locally or set these as Code Engine env/secrets.
